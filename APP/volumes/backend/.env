# ejemplo: https://tu-dominio/reset-password?token={token}
FRONTEND_BASE_URL=${FRONTEND_PUBLIC_URL}
FRONTEND_LOGIN_URL=${FRONTEND_LOGIN_URL}
FRONTEND_RESET_PASSWORD_URL=${FRONTEND_RESET_PASSWORD_URL}
