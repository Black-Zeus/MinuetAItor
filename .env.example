####################################################################################################
# .env.example — MinuetAItor
# --------------------------------------------------------------------------------------------------
# Reglas:
#  - No usar secretos reales en este archivo.
#  - Este ejemplo refleja el wiring real del stack actual.
#  - SMTP operativo se administra desde Sistema >> Integraciones >> SMTP.
####################################################################################################

####################################################################################################
# [BASE] Común a todos los ambientes
####################################################################################################

PROJECT_NAME=MinuetAItor
APP_VERSION=1.0.0
ENV_NAME=base

# Reverse proxy
NGINX_HTTP_PORT=80

# Frontend
FRONTEND_PORT=5173
FRONTEND_PUBLIC_URL=http://localhost:5173
FRONTEND_LOGIN_URL=${FRONTEND_PUBLIC_URL}/login
FRONTEND_RESET_PASSWORD_URL=${FRONTEND_PUBLIC_URL}/reset-password?token={token}
FRONTEND_NAME=MinuetAItor
FRONTEND_ENV=development
FRONTEND_API_URL=http://localhost:8000
FRONTEND_ALLOWED_HOSTS=localhost,127.0.0.1,minuetaitor.vsoto.cl

# Backend interno
BACKEND_PORT=8000
BACKEND_INTERNAL_URL=http://${PROJECT_NAME}-backend:8000
BACKEND_TIMEOUT=30

# MariaDB
MARIADB_HOST=mariadb
MARIADB_PORT=3306
MARIADB_DATABASE=minuetaitor
MARIADB_USER=minuetaitor

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# MinIO
MINIO_HOST=minio
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ROOT_USER=minioadmin
MINIO_SECURE=false

# Herramientas operativas dev/qa
REDISINSIGHT_PORT=5540
MAILPIT_UI_PORT=8025
MAILPIT_SMTP_PORT=1025

# Seguridad
# Los secretos runtime se leen desde .secrets/* y se montan en /run/secrets/*.

# UI / Spinners
PAGE_SPINNER_VARIANT=default
PAGE_SPINNER_SIZE=large
PAGE_SPINNER_TYPE=default
PAGE_SPINNER_SHOW_PROGRESS=false
PAGE_SPINNER_INDETERMINATE=true

# Geo-block
GEO_BLOCK_STATUS=false
GEO_ALLOWED_COUNTRY=["CL","ES"]

# IA / Prompt runtime
ALLOW_PRIVATE_PROVIDER_HOSTS=false
OPENAI_SYSTEM_PROMPT=system_prompt_v08.txt

# Minutas
MINUTES_MAX_FILE_SIZE_MB=50
MINUTES_RATE_LIMIT_PER_DAY=20
MINUTES_STALE_PROCESSING_MINUTES=10

# Worker
WORKER_MAX_CONCURRENT=5
WORKER_MAX_RETRIES=3
WORKER_RETRY_BACKOFF=2.0
WORKER_BLPOP_TIMEOUT=5

# Logging backend / worker
LOG_LEVEL=INFO
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5

# SMTP
# La configuracion operativa de envio se administra en
# Sistema >> Integraciones >> SMTP y se resuelve desde la tabla smtp_configs.

