####################################################################################################
# .env.example — MinuetAItor
# --------------------------------------------------------------------------------------------------
# Unión práctica de:
#   - .env
#   - .env.dev
#   - .env.qa
#   - .env.prd
#   - .env.template
#
# Reglas:
#  - No usar secretos reales en este archivo.
#  - Los bloques DEV/QA/PRD son overrides sugeridos, comentados.
#  - Si una variable derivada usa otras variables, mantener el mismo nombre base.
####################################################################################################

####################################################################################################
# [BASE] Común a todos los ambientes
####################################################################################################

# Identidad del stack
PROJECT_NAME=MinuetAItor
ENV_NAME=base

# Dominio/Host referencial
APP_HOST=localhost

# Reverse proxy / Puertos
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# Frontend / Backend
FRONTEND_PORT=5173
BACKEND_PORT=8000
BACKEND_PUBLIC_URL=http://localhost:8000
FRONTEND_PUBLIC_URL=http://localhost:5173
FRONTEND_LOGIN_URL=${FRONTEND_PUBLIC_URL}/login
FRONTEND_RESET_PASSWORD_URL=${FRONTEND_PUBLIC_URL}/reset-password?token={token}

# Compatibilidad frontend legacy / no-Vite
FRONTEND_NAME=MinuetAItor
FRONTEND_VERSION=1.0.0
FRONTEND_ENV=development
FRONTEND_API_URL=http://localhost:8000

# Frontend Vite
VITE_FRONTEND_NAME=MinuetAItor
VITE_FRONTEND_VERSION=1.0.0
VITE_FRONTEND_ENV=development
VITE_FRONTEND_API_URL=http://localhost:8000

# MariaDB
MARIADB_HOST=mariadb
MARIADB_PORT=3306
MARIADB_DATABASE=minuetaitor
MARIADB_USER=minuetaitor
MARIADB_PASSWORD=__CHANGE_ME__
MARIADB_ROOT_PASSWORD=__CHANGE_ME__
DATABASE_URL=mysql+pymysql://${MARIADB_USER}:${MARIADB_PASSWORD}@${MARIADB_HOST}:${MARIADB_PORT}/${MARIADB_DATABASE}?charset=utf8mb4

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_TIMEOUT=30
REDIS_KEEPALIVE=60

# MinIO
MINIO_HOST=minio
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=__CHANGE_ME__
MINIO_ENDPOINT=http://${MINIO_HOST}:${MINIO_PORT}
MINIO_ACCESS_KEY=${MINIO_ROOT_USER}
MINIO_SECRET_KEY=${MINIO_ROOT_PASSWORD}

# Tools locales
ADMINER_PORT=8080
PHPMYADMIN_PORT=8082
REDISINSIGHT_PORT=5540
MAILPIT_UI_PORT=8025
MAILPIT_SMTP_PORT=1025

# Seguridad
JWT_SECRET=__CHANGE_ME_SUPER_SECRET__
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480
INTERNAL_API_SECRET=__CHANGE_ME_INTERNAL_SECRET__

# IA / OpenAI
OPENAI_API_KEY=__CHANGE_ME_OPENAI_KEY__
OPENAI_MODEL=gpt-4o
OPENAI_ASSISTANT_ID=asst_xxxxxxxxxxxxxxxxxxxx
OPENAI_MAX_TOKENS=16000
OPENAI_TIMEOUT_SECONDS=300
OPENAI_SYSTEM_PROMPT=system_prompt_v08.txt
PROMPTS_PATH=APP/volumes/backend/app/assets/prompts

# Minutas / límites
MINUTES_MAX_FILE_SIZE_MB=50
MINUTES_MAX_FILES_PER_REQUEST=10
MINUTES_RATE_LIMIT_PER_DAY=20
MINUTES_POLLING_INTERVAL_SECONDS=3
MINUTES_MAX_POLLING_ATTEMPTS=100

# Redis TTL / colas
REDIS_TTL_FILE_ID_DAYS=30
REDIS_TTL_TRANSACTION_HOURS=24
REDIS_TTL_LOCK_SECONDS=30

# Worker
WORKER_MAX_CONCURRENT=5
WORKER_MAX_RETRIES=3
WORKER_RETRY_BACKOFF=2.0
WORKER_BLPOP_TIMEOUT=5

# Logging backend
LOG_LEVEL=INFO
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5
TRACE_ENABLED=true

# Logging frontend
LOG_ENABLED=true
LOG_LEVELS=warn,error
LOG_SCOPES=core,auth,error-boundary
LOG_DEFAULT_SCOPE=core
LOG_PREFIX=[MinuetAItor]

# UI / Spinners
PAGE_SPINNER_VARIANT=default
PAGE_SPINNER_SIZE=large
PAGE_SPINNER_TYPE=default
PAGE_SPINNER_SHOW_PROGRESS=false
PAGE_SPINNER_INDETERMINATE=true

# Geo-block
GEO_BLOCK_ENABLED=false
GEO_ALLOWED_COUNTRY=["CL","ES"]

# SMTP / Mailpit
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_USER=no-reply@minuetaitor.cl
SMTP_PASSWORD=
SMTP_FROM_NAME=MinuetAItor DEV
SMTP_FROM_EMAIL=no-reply@minuetaitor.cl
SMTP_USE_TLS=false
SMTP_USE_SSL=false
SMTP_TIMEOUT=10

